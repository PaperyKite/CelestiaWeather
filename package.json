{
  "name": "celestia-weather",
  "version": "0.1.0",
  "description": "基于 OpenLayers 的地图类库，Vue 3 界面已打包进库，开箱即用",
  "type": "module",
  "main": "dist/CelestiaWeather.umd.js",
  "module": "dist/CelestiaWeather.esm.js",
  "exports": {
    ".": {
      "import": "./dist/CelestiaWeather.esm.js",
      "require": "./dist/CelestiaWeather.umd.js"
    },
    "./style.css": "./dist/style.css"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "openlayers",
    "ol",
    "map",
    "vue3",
    "地图",
    "OpenLayers"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/your-username/CelestiaWeather.git"
  },
  "homepage": "https://github.com/your-username/CelestiaWeather#readme",
  "bugs": {
    "url": "https://github.com/your-username/CelestiaWeather/issues"
  },
  "dependencies": {
    "ol": "^8.0.0 || ^9.0.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.0.0",
    "lucide-vue-next": "^0.460.0",
    "vite": "^5.0.0",
    "vue": "^3.4.0",
    "vitepress": "^1.6.4"
  }
}
